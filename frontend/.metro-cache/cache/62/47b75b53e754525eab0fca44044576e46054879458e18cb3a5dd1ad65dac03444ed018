/v2/device/credentials`, {\n          params: {\n            client_id: _configConstants.REAL_DEBRID_CLIENT_ID,\n            code: deviceCode\n          },\n          validateStatus: status => status < 500 // Accept 4xx responses\n        });\n        console.log('[Real-Debrid] Credentials response:', credResponse.status, JSON.stringify(credResponse.data));\n\n        // If we get 403 or error, user hasn't authorized yet\n        if (credResponse.status === 403 || credResponse.data?.error) {\n          console.log('[Real-Debrid] User has not authorized yet (this is normal)');\n          return null;\n        }\n\n        // Check if we have client credentials\n        if (!credResponse.data?.client_id || !credResponse.data?.client_secret) {\n          console.log('[Real-Debrid] No credentials in response yet');\n          return null;\n        }\n        const {\n          client_id,\n          client_secret\n        } = credResponse.data;\n        console.log('[Real-Debrid] Got credentials! Exchanging for token...');\n\n        // Step 2b: Exchange credentials for access token\n        const tokenParams = new URLSearchParams();\n        tokenParams.append('client_id', client_id);\n        tokenParams.append('client_secret', client_secret);\n        tokenParams.append('code', deviceCode);\n        tokenParams.append('grant_type', 'http://oauth.net/grant_type/device/1.0');\n        const tokenResponse = await axios.default.post(`${_configConstants.REAL_DEBRID_BASE_URL}/oauth/v2/token`, tokenParams.toString(), {\n          headers: {\n            'Content-Type': 'application/x-www-form-urlencoded'\n          }\n        });\n        console.log('[Real-Debrid] Token response:', JSON.stringify(tokenResponse.data));\n        if (tokenResponse.data?.access_token) {\n          console.log('[Real-Debrid] SUCCESS! Got access token!');\n\n          // Store refresh token for future use\n          if (tokenResponse.data.refresh_token) {\n            await _utilsStorage.storage.setItem('rd_refresh_token', tokenResponse.data.refresh_token);\n            await _utilsStorage.storage.setItem('rd_client_id', client_id);\n            await _utilsStorage.storage.setItem('rd_client_secret', client_secret);\n          }\n          return {\n            access_token: tokenResponse.data.access_token\n          };\n        }\n        return null;\n      } catch (error) {\n        // 403 means user hasn't authorized yet - this is expected during polling\n        if (error.response?.status === 403) {\n          console.log('[Real-Debrid] Still waiting for user authorization (403)');\n          return null;\n        }\n        console.error('[Real-Debrid] Poll error:', error.response?.data || error.message);\n        return null; // Return null to continue polling instead of throwing\n      }\n    },\n    saveToken: async token => {\n      console.log('[Real-Debrid] Saving token...');\n      await _utilsStorage.storage.setItem(_configConstants.STORAGE_KEYS.REAL_DEBRID_TOKEN, token);\n      const saved = await _utilsStorage.storage.getItem(_configConstants.STORAGE_KEYS.REAL_DEBRID_TOKEN);\n      console.log('[Real-Debrid] Token saved:', saved ? 'YES' : 'NO');\n    },\n    getToken: async () => {\n      const token = await _utilsStorage.storage.getItem(_configConstants.STORAGE_KEYS.REAL_DEBRID_TOKEN);\n      return token;\n    },\n    logout: async () => {\n      await _utilsStorage.storage.deleteItem(_configConstants.STORAGE_KEYS.REAL_DEBRID_TOKEN);\n      await _utilsStorage.storage.deleteItem('rd_refresh_token');\n      await _utilsStorage.storage.deleteItem('rd_client_id');\n      await _utilsStorage.storage.deleteItem('rd_client_secret');\n    },\n    getAccountInfo: async () => {\n      try {\n        const token = await realDebridService.getToken();\n        if (!token) return null;\n        const response = await axios.default.get(`${_configConstants.REAL_DEBRID_BASE_URL}/rest/1.0/user`, {\n          headers: {\n            Authorization: `Bearer $