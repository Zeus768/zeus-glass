        }\n        return false;\n      } catch (error) {\n        console.error('[Premiumize] API key verification failed:', error);\n        return false;\n      }\n    },\n    saveToken: async token => {\n      await _utilsStorage.storage.setItem(_configConstants.STORAGE_KEYS.PREMIUMIZE_TOKEN, token);\n    },\n    getToken: async () => {\n      return await _utilsStorage.storage.getItem(_configConstants.STORAGE_KEYS.PREMIUMIZE_TOKEN);\n    },\n    logout: async () => {\n      await _utilsStorage.storage.deleteItem(_configConstants.STORAGE_KEYS.PREMIUMIZE_TOKEN);\n    },\n    getAccountInfo: async () => {\n      try {\n        const token = await premiumizeService.getToken();\n        if (!token) return null;\n        const response = await axios.default.get(`${_configConstants.PREMIUMIZE_BASE_URL}/account/info`, {\n          params: {\n            apikey: token\n          }\n        });\n        if (response.data.status !== 'success') return null;\n        const data = response.data;\n        const expiryTimestamp = data.premium_until * 1000;\n        const expiryDate = new Date(expiryTimestamp);\n        const daysLeft = Math.ceil((expiryDate.getTime() - Date.now()) / (1000 * 60 * 60 * 24));\n        return {\n          username: data.customer_id?.toString() || 'Premium User',\n          expiryDate: expiryDate.toISOString(),\n          daysLeft,\n          type: data.status === 'premium' ? 'premium' : 'free'\n        };\n      } catch (error) {\n        console.error('[Premiumize] Error fetching account:', error);\n        return null;\n      }\n    },\n    getStreamLinks: async (imdbId, type) => {\n      return [];\n    }\n  };\n\n  // ============================================\n  // DEBRID CACHE SEARCH SERVICE\n  // ============================================\n  const debridCacheService = {\n    searchCachedMovie: async (title, year, imdbId) => {\n      try {\n        const token = await realDebridService.getToken();\n\n        // Search Torrentio regardless of token (token only needed for cache check + playback)\n        if (imdbId) {\n          try {\n            _errorLogService.errorLogService.info(`Calling Torrentio for ${imdbId}`, 'DebridCache');\n            const torrentioResults = await debridCacheService.searchTorrentio(imdbId, 'movie');\n            _errorLogService.errorLogService.info(`Torrentio returned ${torrentioResults.length} results`, 'DebridCache');\n            if (torrentioResults.length > 0) {\n              // Check cache status if we have a token\n              if (token) {\n                try {\n                  const hashes = torrentioResults.map(t => t.hash.toLowerCase());\n                  _errorLogService.errorLogService.info(`Checking cache for ${hashes.length} hashes`, 'DebridCache');\n                  const cachedHashes = await debridCacheService.checkCacheStatus(hashes, token);\n                  _errorLogService.errorLogService.info(`Found ${cachedHashes.length} cached hashes`, 'DebridCache');\n                  return torrentioResults.map(t => Object.assign({}, t, {\n                    cached: cachedHashes.includes(t.hash.toLowerCase())\n                  }));\n                } catch (cacheError) {\n                  _errorLogService.errorLogService.warn(`Cache check failed: ${cacheError.message}, returning unchecked`, 'DebridCache');\n                }\n              } else {\n                _errorLogService.errorLogService.info('No Real-Debrid token - showing torrents without cache status', 'DebridCache');\n              }\n\n              // Return results without cache info\n              return torrentioResults.map(t => Object.assign({}, t, {\n                cached: false\n              }));\n            }\n          } catch (torrentioError) {\n            _errorLogService.errorLogService.warn(`Torrentio failed: ${torrentioError.message}`, 'DebridCache');\n          }\n        }\n\n        // Fallback to backend search if we have token and backend URL\n        if (token) {\n          const backendUrl = _expoVirtualEnv.env.EXPO_PUBLIC_BACKEND_URL || '';\n          if (backendUrl) {\n            try {\n              const params = new URLSearchParams({\n                title,\n                token\n              });\n              if (year) params.append('year', year.toString());\n              if (imdbId) params.append('imdb_id', imdbId);\n              const response = await axios.default.get(`${backendUrl}/api/debrid/cache/search/movie?${params.toString()}`, {\n                timeout: 15000\n              });\n              if (response.data.success) {\n                return response.data.results || [];\n              }\n            } catch (backendError) {\n              _errorLogService.errorLogService.warn(`Backend fallback failed: ${backendError.message}`, 'DebridCache');\n            }\n          }\n        }\n        return [];\n      } catch (error) {\n        _errorLogService.errorLogService.error(`Cache search failed: ${error.message}`, 'DebridCache', error);\n        return [];\n      }\n    },\n    // Torrentio API call - tries direct first (native), falls back to backend proxy (web)\n    searchTorrentio: async (imdbId, type, season, episode) => {\n      try {\n        // Build the URL path\n        let contentPath = `${type}/${imdbId}`;\n        if (type === 'series' && season !== undefined && episode !== undefined) {\n          contentPath += `:${season}:${episode}`;\n        }\n        let streams = [];\n\n        // Try direct Torrentio first (works on native/mobile, may fail on web due to CORS)\n        try {\n          const directUrl = `https://torrentio.strem.fun/stream/${contentPath}.json`;\n          _errorLogService.errorLogService.info(`Trying Torrentio directly: ${directUrl}`, 'Torrentio');\n          const response = await axios.default.get(directUrl, {\n            timeout: 15000,\n            headers: {\n              'User-Agent': 'Mozilla/5.0 (Linux; Android 10) AppleWebKit/537.36'\n            }\n          });\n          streams = response.data?.streams || [];\n          _errorLogService.errorLogService.info(`Torrentio direct: ${streams.length} streams`, 'Torrentio');\n        } catch (directError) {\n          _errorLogService.errorLogService.warn(`Torrentio direct failed: ${directError.message}, trying proxy`, 'Torrentio');\n\n          // Fallback to backend proxy (for web environments)\n          try {\n            const backendUrl = _expoVirtualEnv.env.EXPO_PUBLIC_BACKEND_URL || '';\n            if (backendUrl) {\n              const proxyUrl = `${backendUrl}/api/torrentio/stream/${contentPath}.json`;\n              const proxyResponse = await axios.default.get(proxyUrl, {\n                timeout: 20000\n              });\n              streams = proxyResponse.data?.streams || [];\n              _errorLogService.errorLogService.info(`Torrentio proxy: ${streams.length} streams`, 'Torrentio');\n            }\n          } catch (proxyError) {\n            _errorLogService.errorLogService.warn(`Torrentio proxy also failed: ${proxyError.message}`, 'Torrentio');\n          }\n        }\n        _errorLogService.errorLogService.info(`Torrentio raw streams: ${streams.length}`, 'Torrentio');\n        if (streams.length === 0) {\n          _errorLogService.errorLogService.warn('Torrentio returned 0 streams', 'Torrentio');\n          return [];\n        }\n        const results = streams.slice(0, 60).map(stream => {\n          // Parse info from title - Cinema HD style parsing\n          const title = stream.title || stream.name || '';\n          const behaviorHints = stream.behaviorHints || {};\n\n          // Extract quality\n          let quality = '720p';\n          if (title.match(/4K|2160p|UHD/i)) quality = '4K';else if (title.match(/1080p|FHD/i)) quality = '1080p';else if (title.match(/720p|HD/i)) quality = '720p';else if (title.match(/480p|SD/i)) quality = '480p';\n\n          // Extract size\n          const sizeMatch = title.match(/(\\d+\\.?\\d*)\\s*(GB|MB|gb|mb)/i);\n          const size = sizeMatch ? `${sizeMatch[1]} ${sizeMatch[2].toUpperCase()}` : '';\n\n          // Get hash from infoHash or URL\n          let hash = stream.infoHash || '';\n          if (!hash && stream.url) {\n            // Try to extract from magnet link\n            const magnetMatch = stream.url.match(/btih:([a-fA-F0-9]{40})/i);\n            if (magnetMatch) hash = magnetMatch[1];\n          }\n\n          // Get seeders from title if available\n          const seedMatch = title.match(/(\\d+)\\s*seeder/i);\n          const seeders = seedMatch ? parseInt(seedMatch[1]) : 0;\n\n          // Get source/tracker from title\n          const sourceMatch = title.match(/\\[([^\\]]+)\\]/);\n          const source = sourceMatch ? sourceMatch[1] : 'Torrentio';\n          return {\n            hash: hash.toLowerCase(),\n            title: title,\n            quality: quality.toUpperCase(),\n            size,\n            source,\n            seeders,\n            cached: false,\n            file_id: behaviorHints.videoSize ? 0 : undefined,\n            magnet: stream.url || ''\n          };\n        }).filter(t => t.hash && t.hash.length === 40);\n        _errorLogService.errorLogService.info(`Parsed ${results.length} valid torrents from Torrentio`, 'Torrentio');\n        return results;\n      } catch (error) {\n        _errorLogService.errorLogService.error(`Torrentio search failed: ${error.message}`, 'Torrentio', error);\n        return [];\n      }\n    },\n    // Check cache status directly with Real-Debrid\n    checkCacheStatus: async (hashes, token) => {\n      try {\n        if (hashes.length === 0) return [];\n\n        // Real-Debrid instant availability check\n        const hashParam = hashes.join('/');\n        const response = await axios.default.get(`https://api.real-debrid.com/rest/1.0/torrents/instantAvailability/${hashParam}`, {\n          headers: {\n            Authorization: `Bearer ${token}`\n          },\n          timeout: 10000